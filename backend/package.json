{
  "name": "consulta-practica-backend",
  "version": "2.0.0",
  "description": "Backend API para Consulta Práctica Web — Node.js + Fastify + Clean Architecture",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/tests/use-cases.test.ts",
    "etl": "tsx src/interfaces/etl/index.ts",
    "etl:dry": "tsx src/interfaces/etl/index.ts --dry-run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@supabase/supabase-js": "^2.110.8",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.0",
    "jsonwebtoken": "^9.0.3",
    "node-adodb": "^5.0.3",
    "node-cron": "^4.6.0",
    "pdfkit": "^0.15.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.13.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
